  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.14.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/tsconfig": "^0.5.1",
    "npm-run-all2": "^6.2.0",
    "rollup-plugin-gzip": "^4.0.1",
    "sass-embedded": "^1.77.8",
    "terser": "^5.37.0",
    "typescript": "~5.4.0",
