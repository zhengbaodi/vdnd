{
  "name": "@vdnd/v3",
  "version": "1.0.0-beta.1",
  "type": "module",
  "module": "dist/index.mjs",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "description": "The simple vue drag and drop component library.",
  "keywords": [
    "vdnd",
    "vue-dnd",
    "vue2-dnd",
    "vue3-dnd",
    "drag and drop",
    "vue drag and drop"
  ],
  "files": [
    "dist/index.mjs",
    "dist/index.cjs",
    "dist/index.d.ts"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhengbaodi/vdnd"
  },
  "homepage": "https://zhengbaodi.github.io/vdnd/",
  "bugs": {
    "url": "https://github.com/zhengbaodi/vdnd/issues",
    "email": "zhengbaodi329@outlook.com"
  },
  "scripts": {
    "pretest": "pnpm link ./test-utils",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "type-check:runtime": "tsc --project tsconfig.build.json --noEmit",
    "rollup": "rollup -c rollup.config.js",
    "rollup:dts": "rollup -c rollup.config.dts.js",
    "prebuild": "rimraf dist",
    "build": "pnpm rollup && pnpm rollup:dts",
    "postbuild": "rimraf dist/types",
    "format": "prettier --write \"./(docs|src|test-utils|types)/**/*.{js,ts}\" \"./**/*.md\"",
    "prepublish": "pnpm type-check && pnpm test -- --coverage.enabled=false && pnpm format && pnpm build",
    "postpublish": "rimraf dist"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.17.16",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.32.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": "20.18.1"
  }
}
